{
	"name": "@open-grid/react",
	"version": "1.0.0",
	"description": "React bindings for the headless high-performance spreadsheet and grid engine core",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.d.ts",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"scripts": {
		"prebuild": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
		"build": "tsc",
		"watch": "tsc --watch",
		"test": "vitest run"
	},
	"dependencies": {
		"@open-grid/core": "workspace:*"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.1"
	},
	"keywords": [
		"react",
		"headless",
		"grid",
		"spreadsheet",
		"performance"
	],
	"author": "Rishikesh Kumar",
	"license": "MIT"
}
